datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["views"]
}

enum UserRole {
  FleetManager     @map("Fleet Manager")
  Driver           @map("Driver")
  SafetyOfficer    @map("Safety Officer")
  FinancialAnalyst @map("Financial Analyst")
}

model User {
  id       Int      @id @default(autoincrement())
  email    String   @unique
  password String
  name     String
  role     UserRole

  @@map("transit_user")
}

enum VehicleStatus {
  Available
  OnTrip    @map("On Trip")
  InShop    @map("In Shop")
  Retired
}

model TransitVehicle {
  id                 Int                     @id @default(autoincrement())
  registrationNumber String                  @unique @map("registration_number")
  modelName          String                  @map("model_name")
  vehicleType        String                  @map("vehicle_type")
  maxLoadCapacity    Float                   @map("max_load_capacity")
  currentOdometer    Float                   @map("current_odometer")
  acquisitionCost    Float                   @map("acquisition_cost")
  status             VehicleStatus           @default(Available)
  trips              TransitTrip[]
  maintenanceLogs    TransitMaintenanceLog[]
  fuelLogs           TransitFuelLog[]
  expenses           TransitExpense[]

  @@map("transit_vehicle")
}

enum DriverStatus {
  Available
  OnTrip    @map("On Trip")
  OffDuty   @map("Off Duty")
  Suspended
}

model TransitDriver {
  id                Int          @id @default(autoincrement())
  name              String
  licenseNumber     String       @unique @map("license_number")
  licenseCategory   String       @map("license_category")
  licenseExpiryDate DateTime     @map("license_expiry_date")
  contactNumber     String       @map("contact_number")
  safetyScore       Float        @map("safety_score")
  status            DriverStatus @default(Available)
  trips             TransitTrip[]

  @@map("transit_driver")
}

enum TripStatus {
  Draft
  Dispatched
  Completed
  Cancelled
}

model TransitTrip {
  id                     Int            @id @default(autoincrement())
  source                 String
  destination            String
  vehicleId              Int            @map("vehicle_id")
  driverId               Int            @map("driver_id")
  cargoWeight            Float          @map("cargo_weight")
  plannedDistance        Float          @map("planned_distance")
  actualDistanceTraveled Float?         @map("actual_distance_traveled")
  fuelConsumed           Float?         @map("fuel_consumed")
  revenue                Float
  status                 TripStatus     @default(Draft)
  createdAt              DateTime       @default(now()) @map("created_at")

  vehicle                TransitVehicle @relation(fields: [vehicleId], references: [id])
  driver                 TransitDriver  @relation(fields: [driverId], references: [id])

  @@map("transit_trip")
  @@index([vehicleId])
  @@index([driverId])
}

enum MaintenanceStatus {
  Active
  Closed
}

model TransitMaintenanceLog {
  id          Int               @id @default(autoincrement())
  vehicleId   Int               @map("vehicle_id")
  description String
  cost        Float
  status      MaintenanceStatus @default(Active)
  date        DateTime          @default(now())

  vehicle     TransitVehicle    @relation(fields: [vehicleId], references: [id])

  @@map("transit_maintenance_log")
  @@index([vehicleId])
}

model TransitFuelLog {
  id              Int            @id @default(autoincrement())
  vehicleId       Int            @map("vehicle_id")
  liters          Float
  cost            Float
  odometerReading Float          @map("odometer_reading")
  date            DateTime       @default(now())

  vehicle         TransitVehicle @relation(fields: [vehicleId], references: [id])

  @@map("transit_fuel_log")
  @@index([vehicleId])
}

model TransitExpense {
  id          Int            @id @default(autoincrement())
  vehicleId   Int            @map("vehicle_id")
  expenseType String         @map("expense_type")
  amount      Float
  date        DateTime       @default(now())
  description String?

  vehicle     TransitVehicle @relation(fields: [vehicleId], references: [id])

  @@map("transit_expense")
  @@index([vehicleId])
}

view VehicleAnalytics {
  id                   Int    @unique
  registrationNumber   String @map("registration_number")
  modelName            String @map("model_name")
  acquisitionCost      Float  @map("acquisition_cost")
  totalRevenue         Float  @map("total_revenue")
  totalFuelCost        Float  @map("total_fuel_cost")
  totalMaintenanceCost Float  @map("total_maintenance_cost")
  totalOtherExpenses   Float  @map("total_other_expenses")
  totalOperationalCost Float  @map("total_operational_cost")
  netProfit            Float  @map("net_profit")
  totalDistance        Float  @map("total_distance")
  totalFuelLiters      Float  @map("total_fuel_liters")
  fuelEfficiency       Float  @map("fuel_efficiency")
  roi                  Float  @map("roi")

  @@map("vehicle_analytics")
}
